# =============================================================================
# Investor Ops & Intelligence Suite — environment template
# Copy to .env (never commit .env). See ARCHITECTURE.md §3 for persistence.
# =============================================================================

# --- URLs & CORS ---
FRONTEND_URL=http://localhost:3000
# Next.js (Vercel): public backend base URL, no trailing slash
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# FastAPI (Render): comma-separated origins for CORS, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# --- Database (required in production for durable bookings/reviews/memory) ---
# Use PostgreSQL on Render (or Docker locally). Example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/investor_ops
# Local SQLAlchemy sync URL for scripts if needed:
# DATABASE_URL_SYNC=postgresql://user:pass@host:5432/investor_ops
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/investor_ops

# Optional: disable pgvector and store chunks only (re-embed on startup/admin)
# USE_PGVECTOR=true

# --- LLM (when set, chat uses real LLM calls: orchestrator routing+synthesis, RAG plan+synthesize, scheduling voice) ---
GROQ_API_KEY=
# Primary model id (adjust per Groq availability)
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=
# Google AI Studio generateContent model id (fallback if Groq fails or is unset)
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Google (direct APIs; service account JSON as single-line or path) ---
# Option A: path to JSON file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: base64-encoded service account JSON (Render secret)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

GOOGLE_CALENDAR_ID=
GOOGLE_SHEET_ID=
GOOGLE_DOC_ID=
GOOGLE_INTEGRATIONS_MODE=mock

# Advisor self-serve booking: max calendar days from today (inclusive window)
BOOKING_MAX_DAYS_AHEAD=120

# --- Gmail SMTP (advisor + pulse emails; HITL send only) ---
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# --- Play Store / reviews ---
PLAY_STORE_APP_ID=com.nextbillion.groww
# Path to CSV fallback when scraping fails (relative to backend cwd)
REVIEWS_FALLBACK_CSV=sample_data/reviews_fallback.csv

# --- Embeddings / ML ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ML_KMEANS_K_MIN=3
ML_KMEANS_K_MAX=8

# --- Ops ---
LOG_LEVEL=INFO
# Secret for optional cron/admin hooks (if added later)
INTERNAL_JOB_SECRET=
